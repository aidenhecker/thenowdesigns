# Optional production scanner proxy. If blank, the UI uses Microlink's public
# low-volume endpoint. Set this before sending paid traffic.
VITE_SCAN_API_URL=

# Public Whop checkout URL for the Website Repair Sprint. When blank, qualified
# buyers submit their scan and receive a scope-confirmed Whop checkout instead.
VITE_WHOP_REPAIR_URL=

# Web3Forms access keys are designed for browser forms. The existing site key
# remains the fallback so this variable is optional.
VITE_WEB3FORMS_ACCESS_KEY=
