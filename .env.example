# Optional production scanner proxy. If blank, the UI uses Microlink's public
# low-volume endpoint. Set this before sending paid traffic.
VITE_SCAN_API_URL=

# Fail closed to the no-payment scope form. Change this to whop_waitlist only
# after every configured Whop link is a waitlist with required Website URL and
# Scan reference questions. Direct-charge checkout is intentionally disabled
# until a scope-mismatch/refund policy is approved.
VITE_CHECKOUT_MODE=scope_review

# Public Whop waitlist URLs for the deterministic repair tiers. Blank or
# manual-review tiers fall back to the scope-confirmation form. Tier five stays
# manual until its $4,500+ route is defined as a fixed base price or deposit.
VITE_WHOP_TIER_1_URL=
VITE_WHOP_TIER_2_URL=
VITE_WHOP_TIER_3_URL=
VITE_WHOP_TIER_4_URL=
VITE_WHOP_TIER_5_URL=

# Public Cloudflare Worker endpoint, including /v1/preview. Leave blank until
# the Worker secret and rate limiter are configured; the AI concept UI stays hidden.
VITE_PREVIEW_API_URL=

# Web3Forms access keys are designed for browser forms. The existing site key
# remains the fallback so this variable is optional.
VITE_WEB3FORMS_ACCESS_KEY=

# Worker-only secret for local development. Never rename this with a VITE_
# prefix and never commit its value. Production stores it as a Worker secret.
OPENROUTER_API_KEY=
